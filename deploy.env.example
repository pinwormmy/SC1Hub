# Copy to .deploy.env and adjust only if your Cafe24 settings differ.
DEPLOY_HOST=sc1hub-prod
DEPLOY_USER=
REMOTE_TOMCAT_DIR=/home/hosting_users/sc1hub/tomcat
REMOTE_SCRIPT_DIR=/home/hosting_users/sc1hub/scripts
REMOTE_WAR_NAME=ROOT.war

# Cafe24 JSP hosting commonly uses per-account Tomcat scripts.
# Leave these as-is unless your hosting panel documents different commands.
REMOTE_STOP_CMD='$REMOTE_TOMCAT_DIR/bin/shutdown.sh'
REMOTE_START_CMD='$REMOTE_TOMCAT_DIR/bin/startup.sh'
